{
    "version": 2,
    "buildCommand": "npm run build && composer install --optimize-autoloader --no-dev",
    "functions": {
        "api/index.php": {
            "runtime": "now-php@1.0.0"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
