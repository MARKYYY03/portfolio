{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "nixpacksConfig": {
      "providers": ["php", "nodejs"]
    }
  },
  "deploy": {
    "startCommand": "vendor/bin/heroku-php-apache2 public/",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  }
}
